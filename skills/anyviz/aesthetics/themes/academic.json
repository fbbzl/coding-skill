{
  "name": "Academic",
  "version": "1.0.0",
  "description": "学术论文主题。灰度安全、极简克制，适合期刊投稿和学术出版物，打印友好。",
  "use_cases": ["学术论文", "期刊投稿", "科学研究", "学位论文", "印刷出版"],

  "color": {
    "categorical": {
      "palette": [
        "#333333",
        "#666666",
        "#999999",
        "#BBBBBB",
        "#DDDDDD",
        "#888888",
        "#AAAAAA",
        "#777777",
        "#555555",
        "#444444"
      ]
    },
    "sequential": {
      "single_hue": { "name": "Grays", "palette": ["#F5F5F5","#E0E0E0","#CCCCCC","#B0B0B0","#909090","#707070","#505050","#303030","#101010"] },
      "multi_hue": { "name": "Viridis", "palette": ["#440154","#482878","#3E4A89","#31688E","#26828E","#1F9E89","#35B779","#6DCD59","#B4DE2C","#FDE725"] }
    },
    "diverging": {
      "palette": ["#666666","#888888","#AAAAAA","#DDDDDD","#FFFFFF","#DDDDDD","#AAAAAA","#888888","#666666"]
    },
    "highlight": {
      "primary": "#333333",
      "comparison": "#666666",
      "positive": "#333333",
      "negative": "#999999"
    },
    "background": { "chart": "#FFFFFF", "page": "#FFFFFF", "grid": "#E8E8E8", "border": "#CCCCCC" },
    "text": { "primary": "#000000", "secondary": "#444444", "tertiary": "#666666", "muted": "#888888" }
  },

  "typography": {
    "font_family": {
      "default": "serif"
    }
  },

  "style": {
    "bar": { "corner_radius_px": 0 },
    "line": { "interpolation": "linear", "width_px": 1.5 },
    "point": { "border_width_px": 0, "border_color": "#FFFFFF" },
    "axis": { "tick_length_px": 5, "label_offset_px": 4 },
    "grid": { "show_x": false, "show_y": false }
  }
}
