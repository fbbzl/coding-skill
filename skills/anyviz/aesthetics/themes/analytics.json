{
  "name": "Analytics",
  "version": "1.0.0",
  "description": "数据分析报告主题。色调沉稳专业，适合白底报告与 PPT 演示，中低饱和度，长时间阅读不疲劳。",
  "use_cases": ["数据分析报告", "商业汇报", "PPT", "PDF报告", "邮件报表"],

  "color": {
    "categorical": {
      "palette": [
        "#5B7FBD",
        "#6AA66A",
        "#D4756B",
        "#8B7DB8",
        "#C4A24E",
        "#6FB3C4",
        "#9E9E9E",
        "#E8963E",
        "#7CB342",
        "#D47FA6"
      ]
    },
    "sequential": {
      "single_hue": { "name": "Blues", "palette": ["#F0F6FC","#D6E6F5","#B2D0EC","#87B6E0","#5B9BD5","#3B7CC3","#2C62A8","#1F4E8A","#153B6B"] },
      "multi_hue": { "name": "Viridis", "palette": ["#440154","#482878","#3E4A89","#31688E","#26828E","#1F9E89","#35B779","#6DCD59","#B4DE2C","#FDE725"] }
    },
    "diverging": {
      "palette": ["#8C510A","#BF812D","#DFC27D","#F6E8C3","#F5F5F5","#C7EAE5","#80CDC1","#35978F","#01665E"]
    },
    "highlight": {
      "primary": "#5B7FBD",
      "comparison": "#D4756B",
      "positive": "#6AA66A",
      "negative": "#D4756B"
    },
    "background": { "chart": "#FFFFFF", "page": "#F7F8FA", "grid": "#EAEAEC", "border": "#D5D5D8" },
    "text": { "primary": "#1A1A1A", "secondary": "#5A5A5A", "tertiary": "#707070", "muted": "#909090" }
  },

  "style": {
    "bar": { "corner_radius_px": 4 },
    "line": { "interpolation": "monotone", "width_px": 2.2 },
    "point": { "border_width_px": 1.5, "border_color": "#FFFFFF" },
    "axis": { "tick_length_px": 4, "label_offset_px": 6 },
    "grid": { "show_x": false, "show_y": true }
  }
}
