{
  "name": "Modern",
  "version": "1.0.0",
  "description": "现代通用主题。色彩明快但不刺眼，适合网页嵌入、交互式可视化、产品内嵌图表。是 anyviz 的默认主题。",
  "use_cases": ["网页嵌入", "交互可视化", "产品图表", "社交媒体", "通用场景"],

  "color": {
    "categorical": {
      "palette": [
        "#5B8DE0",
        "#4CB880",
        "#EE7B6F",
        "#9B7ED8",
        "#E8B33F",
        "#5CC0C8",
        "#9CA3AF",
        "#F09050",
        "#A3C95A",
        "#E87DB5"
      ]
    },
    "sequential": {
      "single_hue": { "name": "Blues", "palette": ["#EBF3FC","#D1E3F7","#AECFEF","#84B9E4","#5BA3D9","#3A8CCC","#2672B0","#1A5A94","#104478"] },
      "multi_hue": { "name": "Viridis", "palette": ["#440154","#482878","#3E4A89","#31688E","#26828E","#1F9E89","#35B779","#6DCD59","#B4DE2C","#FDE725"] }
    },
    "diverging": {
      "palette": ["#C98936","#DEB866","#EFDFA4","#F7F3E2","#F5F5F5","#DCE9EC","#A5CED6","#5FA8B8","#2D8296"]
    },
    "highlight": {
      "primary": "#5B8DE0",
      "comparison": "#EE7B6F",
      "positive": "#4CB880",
      "negative": "#EE7B6F"
    },
    "background": { "chart": "#FFFFFF", "page": "#FAFBFC", "grid": "#EDEEF0", "border": "#E0E2E6" },
    "text": { "primary": "#1A1A1A", "secondary": "#5A5A5A", "tertiary": "#6E6E6E", "muted": "#909090" }
  },

  "style": {
    "bar": { "corner_radius_px": 5 },
    "line": { "interpolation": "monotone", "width_px": 2.2 },
    "point": { "border_width_px": 2.0, "border_color": "#FFFFFF" },
    "axis": { "tick_length_px": 4, "label_offset_px": 6 },
    "grid": { "show_x": false, "show_y": true }
  }
}
