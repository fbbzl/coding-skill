{
  "name": "Dashboard",
  "version": "1.0.0",
  "description": "数据大屏主题。高对比度、深色背景优化、发光质感，适合大屏监控和数据产品仪表盘。",
  "use_cases": ["数据大屏", "监控面板", "深色仪表盘", "数据产品", "实时看板"],

  "color": {
    "categorical": {
      "palette": [
        "#5E9CF3",
        "#4DD9C1",
        "#FF6B7A",
        "#B388FF",
        "#FFC048",
        "#40C4FF",
        "#8E99A4",
        "#FF8A65",
        "#69F0AE",
        "#FF80AB"
      ]
    },
    "sequential": {
      "single_hue": { "name": "Blues", "palette": ["#0D2137","#163A5C","#1F5381","#286CA6","#3385CB","#499FDE","#65B9EE","#81D4FA","#9EEAFF"] },
      "multi_hue": { "name": "Viridis", "palette": ["#440154","#482878","#3E4A89","#31688E","#26828E","#1F9E89","#35B779","#6DCD59","#B4DE2C","#FDE725"] }
    },
    "diverging": {
      "palette": ["#BF812D","#DFC27D","#F6E8C3","#F5F5F5","#C7EAE5","#80CDC1","#35978F"]
    },
    "highlight": {
      "primary": "#5E9CF3",
      "comparison": "#FF6B7A",
      "positive": "#4DD9C1",
      "negative": "#FF6B7A"
    },
    "background": { "chart": "#0F1923", "page": "#0A1119", "grid": "#1A2A3A", "border": "#1E3040" },
    "text": { "primary": "#E8EDF2", "secondary": "#8899AA", "tertiary": "#6B7D8E", "muted": "#556677" }
  },

  "style": {
    "bar": { "corner_radius_px": 6 },
    "line": { "interpolation": "monotone", "width_px": 2.5 },
    "point": { "border_width_px": 2.0, "border_color": "#0F1923" },
    "axis": { "tick_length_px": 3, "label_offset_px": 8 },
    "grid": { "show_x": false, "show_y": true },
    "glow": { "enabled": true, "radius_px": 8, "opacity": 0.15 }
  }
}
