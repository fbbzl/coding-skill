{
  "name": "anyviz Default",
  "version": "1.0.0",
  "description": "基于 Observable Plot 设计理念的默认可视化主题，色彩明亮、灰度克制，适用于现代商业报告和通用数据展示场景",

  "color": {
    "categorical": {
      "description": "分类数据色板 — 受 Observable Plot 现代配色启发，用于无顺序关系的类别对比。颜色明亮、灰度克制",
      "max_items": 10,
      "palette": [
        "#4269d0",
        "#3ca951",
        "#ff725c",
        "#a463f2",
        "#efb118",
        "#6cc5b0",
        "#9696a0",
        "#f5a623",
        "#ca5bb8",
        "#ff8ab7"
      ],
      "color_blind_safe": true,
      "grayscale_distinguishable": true
    },

    "sequential": {
      "description": "顺序数据色板 — 用于从低到高的数值渐变",
      "single_hue": {
        "name": "Blues",
        "palette": ["#F7FBFF", "#DEEBF7", "#C6DBEF", "#9ECAE1", "#6BAED6", "#4292C6", "#2171B5", "#08519C", "#08306B"],
        "reverse": false
      },
      "multi_hue": {
        "name": "Viridis",
        "palette": ["#440154", "#482878", "#3E4A89", "#31688E", "#26828E", "#1F9E89", "#35B779", "#6DCD59", "#B4DE2C", "#FDE725"],
        "perceptually_uniform": true,
        "color_blind_safe": true
      }
    },

    "diverging": {
      "description": "发散色板 — 用于有中点的双向数据（如正负值、偏差）",
      "palette": ["#8C510A", "#BF812D", "#DFC27D", "#F6E8C3", "#F5F5F5", "#C7EAE5", "#80CDC1", "#35978F", "#01665E"],
      "center_value": 0,
      "center_color": "#F5F5F5"
    },

    "highlight": {
      "primary": "#4269d0",
      "comparison": "#ff725c",
      "reference_positive": "#3ca951",
      "reference_negative": "#ff725c"
    },

    "background": {
      "chart": "#FFFFFF",
      "page": "#FAFAFA",
      "grid": "#E8E8E8",
      "border": "#D0D0D0"
    },

    "text": {
      "primary": "#1A1A1A",
      "secondary": "#555555",
      "tertiary": "#666666",
      "muted": "#888888"
    }
  },

  "typography": {
    "font_family": {
      "sans_serif": "'Helvetica Neue', Helvetica, Arial, 'PingFang SC', 'Microsoft YaHei', sans-serif",
      "serif": "'Georgia', 'Times New Roman', 'Songti SC', 'SimSun', serif",
      "monospace": "'Menlo', 'Monaco', 'Courier New', monospace",
      "default": "sans_serif"
    },

    "scale": {
      "h1": { "element": "图表主标题", "size_px": 16, "weight": 600, "color": "var(--text-primary)", "line_height": 1.3 },
      "h2": { "element": "子标题/副标题", "size_px": 13, "weight": 400, "color": "var(--text-secondary)", "line_height": 1.3 },
      "h3": { "element": "轴标题", "size_px": 11, "weight": 400, "color": "#333333", "line_height": 1.3 },
      "h4": { "element": "刻度标签", "size_px": 10, "weight": 400, "color": "var(--text-tertiary)", "line_height": 1.3 },
      "h5": { "element": "图例文本", "size_px": 10, "weight": 400, "color": "var(--text-secondary)", "line_height": 1.3 },
      "h6": { "element": "数据标签/脚注/来源", "size_px": 9, "weight": 400, "color": "var(--text-muted)", "line_height": 1.3 }
    },

    "number_format": {
      "decimal_places": 1,
      "use_thousands_separator": true,
      "percentage_decimals": 1,
      "currency_symbol": "¥",
      "scientific_notation_threshold": 1000000,
      "date_format_short": "%m/%d",
      "date_format_long": "%Y-%m-%d",
      "abbreviate_large_numbers": true
    }
  },

  "spacing": {
    "chart_margin": { "top": 48, "right": 36, "bottom": 56, "left": 56 },
    "chart_margin_small": { "top": 32, "right": 24, "bottom": 40, "left": 48 },
    "multi_chart_gap": 28,
    "element_padding": 10,
    "legend_item_gap": 14,
    "title_to_chart_gap": 10,
    "axis_label_to_tick_gap": 8,
    "data_label_offset": 6
  },

  "stroke": {
    "line": { "width_px": 2.2, "cap": "round", "join": "round", "interpolation": "monotone" },
    "line_emphasis": { "width_px": 3.2 },
    "line_deemphasis": { "width_px": 1.0, "opacity": 0.25 },
    "grid": { "width_px": 0.5, "color": "#E8E8E8", "dash": [2, 2], "style": "dashed", "show_x": false, "show_y": true },
    "axis": { "width_px": 0.8, "color": "#CCCCCC", "style": "solid", "tick_length_px": 4, "tick_width_px": 0.8 },
    "axis_zero": { "width_px": 0.8, "color": "#BBBBBB", "style": "solid" },
    "reference_line": { "width_px": 1.0, "color": "#EE7B6F", "dash": [4, 4], "opacity": 0.7 },
    "trend_line": { "width_px": 1.5, "color": "#EE7B6F", "dash": [6, 3], "opacity": 0.6 }
  },

  "point": {
    "scatter": { "radius_px": 4.5, "opacity": 0.75, "stroke_width_px": 2.0, "stroke_color": "#FFFFFF" },
    "line_data_point": { "radius_px": 3.5, "opacity": 1.0, "stroke_width_px": 1.5, "stroke_color": "#FFFFFF" },
    "highlight_point": { "radius_px": 6.0, "opacity": 1.0, "stroke_width_px": 2.5, "stroke_color": "#333333" },
    "outlier_point": { "radius_px": 4.5, "opacity": 0.6, "style": "x" }
  },

  "area": {
    "opacity": 0.12,
    "stacked_opacity": 0.65,
    "gradient_top_opacity": 0.25,
    "gradient_bottom_opacity": 0.0
  },

  "bar": {
    "width_ratio": 0.65,
    "corner_radius_px": 5,
    "min_height_px": 2,
    "label_position": "outside",
    "label_offset_px": 6
  },

  "annotation": {
    "callout_line": { "width_px": 1.0, "color": "#555555", "dash": [3, 3] },
    "callout_circle": { "radius_px": 5, "stroke_width_px": 2.0, "fill": "none" },
    "highlight_band": { "fill_color": "#4269d0", "opacity": 0.08 },
    "tooltip_font_size_px": 11,
    "tooltip_background": "#FFFFFF",
    "tooltip_border": "#D0D0D0"
  },

  "legend": {
    "position": "top",
    "orientation": "horizontal",
    "item_gap": 16,
    "symbol_size_px": 10,
    "symbol_stroke_width_px": 0,
    "max_items_before_wrap": 6
  },

  "axis": {
    "x_axis": {
      "tick_rotation": 0,
      "max_tick_rotation": 45,
      "tick_count_suggestion": 6,
      "label_overflow": "truncate"
    },
    "y_axis": {
      "tick_count_suggestion": 5,
      "include_zero": false,
      "grid_lines_enabled": true,
      "minor_grid_lines": false
    }
  },

  "accessibility": {
    "contrast_ratio_minimum": 4.5,
    "color_blind_friendly_palettes": true,
    "min_touch_target_px": 44,
    "alt_text_template": "{chart_type} 图表，展示 {data_description}。X 轴：{x_axis_label}，Y 轴：{y_axis_label}。"
  },

  "responsive": {
    "breakpoints": {
      "mobile": { "max_width_px": 640, "font_scale": 0.85, "margin_scale": 0.7 },
      "tablet": { "max_width_px": 1024, "font_scale": 0.92, "margin_scale": 0.85 },
      "desktop": { "max_width_px": 999999, "font_scale": 1.0, "margin_scale": 1.0 }
    },
    "aspect_ratio": {
      "default": 1.6,
      "wide": 2.0,
      "square": 1.0,
      "portrait": 0.75
    }
  }
}
